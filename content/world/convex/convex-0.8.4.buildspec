groupId=world.convex
artifactId=convex
version=0.8.4

display=${groupId}:${artifactId}

gitRepo=https://github.com/Convex-Dev/${artifactId}.git
gitTag=${version}

tool=mvn-3.9.12
jdk=25
newline=crlf

command="mvn -Prelease clean verify -DskipTests -Dmaven.javadoc.skip -Dgpg.skip"
execBefore="mkdir convex-db/src/main/java/convex/db/server" # should not be necessary, but ...

buildinfo=target/${artifactId}-${version}.buildinfo

#diffoscope=${artifactId}-${version}.diffoscope
issue=
