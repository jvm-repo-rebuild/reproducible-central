groupId=org.glassfish.hk2
artifactId=hk2-parent
version=4.0.0

display=${groupId}:${artifactId}

gitRepo=https://github.com/eclipse-ee4j/glassfish-hk2.git
gitTag=${version}

tool=mvn-3.9.12
jdk=21
newline=lf
umask=022

command="mvn -Poss-release clean package -DskipTests -Dmaven.javadoc.skip -Dgpg.skip -DskipSBOM -Dbuildinfo.skipModules='*/hk2-di-tck-runner'"
execBefore="find . -type d -exec chmod g+s {} \;"

buildinfo=target/${artifactId}-${version}.buildinfo

#diffoscope=${artifactId}-${version}.diffoscope
issue=

