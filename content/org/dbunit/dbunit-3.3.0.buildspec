groupId=org.dbunit
artifactId=dbunit
display=${groupId}:${artifactId}
version=3.3.0

gitRepo=https://github.com/dbunit/dbunit-extension.git
gitTag=${artifactId}-${version}

tool=mvn-3.9.12
jdk=21
newline=lf
#umask=022

command="mvn -Prelease,oracle-default clean verify -DsurefirePluginSkip -DskipTests -Dmaven.javadoc.skip -Dgpg.skip"
buildinfo=target/${artifactId}-${version}.buildinfo

#diffoscope=${artifactId}-${version}.diffoscope
issue=
