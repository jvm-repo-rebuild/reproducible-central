groupId=it.mulders.puml
artifactId=puml-parent
display=${groupId}:${artifactId}
version=0.5.2

gitRepo=https://github.com/mthmulders/puml-maven-plugin.git
gitTag=v0.5.2

tool=mvn-3.9.16
jdk=21
newline=lf

command="mvn -Prelease clean package -DskipTests -Dmaven.javadoc.skip -Dgpg.skip -Dbuildinfo.detect.skip=false -pl !:plugin-tests"
buildinfo=target/${artifactId}-${version}.buildinfo

issue=
