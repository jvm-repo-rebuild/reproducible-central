groupId=it.mulders.stryker
artifactId=pit-dashboard-reporter
display=${groupId}:${artifactId}
version=0.3.18

gitRepo=https://github.com/mthmulders/pit-stryker-dashboard-reporter.git
gitTag=v${version}

tool=mvn-3.9.16
jdk=11
newline=lf

command="mvn -Prelease clean package -DskipTests -Dmaven.javadoc.skip -Dgpg.skip -Dbuildinfo.detect.skip=false"
buildinfo=target/${artifactId}-${version}.buildinfo

issue=
